# --- host user (must own ${APPDATA} and ${MEDIA}) ---
PUID=1000
PGID=1000

# --- AMD GPU render group GID (check with `getent group render`) ---
RENDER_GID=993

# --- timezone (IANA) ---
TZ=Etc/UTC

# --- paths on the host ---
APPDATA=/opt/appdata
MEDIA=/mnt/media

# --- LAN IP of this host (used in setup docs only) ---
SERVER_IP=192.168.100.5
